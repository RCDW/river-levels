.env
.env.*
!.env.example
# W6 reference material: skeleton-shaped Azure files used as a porting source.
# Local-only; the real files are adapted into the repo (ingest/, transform/, etc.).
.w6-reference/
# Locally-generated pipeline data. The scheduled pipeline force-adds the
# published artifacts to the `data` branch (git add -f bypasses this), so they
# never land on a code branch from a local run. The warehouse is rebuilt each run.
data/river.duckdb
data/bronze/
web/data/
transform/target/
transform/dbt_packages/
transform/logs/
__pycache__/
*.pyc
.venv/
node_modules/
dist/
.turbo/
*.log
# TypeScript incremental build cache (regenerated by `tsc -b`)
*.tsbuildinfo
# Playwright (smoke test) outputs
test-results/
playwright-report/
# Lighthouse CI run output
.lighthouseci/
# Terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/crash.log
infra/crash.*.log
infra/*.tfvars.json
infra/.terraform/
infra/terraform.tfvars